{
  "/ws": {
    "authScope": null,
    "middlewares": [],
    "wsActionsAvailable": null,
    "description": "Every guest and user allowed channel"
  },
  "/ws/auth": {
    "authScope": null,
    "middlewares": [
      "auth"
    ],
    "wsActionsAvailable": null,
    "description": "Only auth users allowed channel"
  },
  "/ws/auth/private/{user_id}": {
    "authScope": "user_{user_id}",
    "middlewares": [
      "auth"
    ],
    "transport": [
      "websocket"
    ],
    "description": "Only one auth user allowed channel (user private)"
  },
  "/ws/auth/admin": {
    "authScope": "admin",
    "middlewares": [
      "auth"
    ],
    "wsActionsAvailable": [
      "hello@index",
      "post-data@index"
    ],
    "description": "Only admin auth users allowed channel"
  },
  "/ws/auth/admin/{user_id}": {
    "authScope": [
      "admin",
      "user_{user_id}"
    ],
    "middlewares": [
      "auth",
      "csrf"
    ],
    "wsActionsAvailable": [
      "hello@index",
      "post-data@index"
    ],
    "description": "Only one admin auth user allowed channel (admin private)"
  }
}
